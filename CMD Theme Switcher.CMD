@echo off
@title CMD Theme Switcher

where powershell >nul 2>&1
if %errorlevel% neq 0 (
    color 0c
    echo.
    echo ERROR: Windows PowerShell is required!
    pause
    exit /b
)

powershell -NoProfile -ExecutionPolicy Bypass -Command "Add-Type -AssemblyName System.Windows.Forms; function Clean-AutoRun($v){if(!$v){return $null};$v=$v -replace 'color [0-9A-Fa-f]{2}','';$v=$v -replace 'if exist \"[^\"]*CMDTheme\\theme\.cmd\" call \"[^\"]*CMDTheme\\theme\.cmd\"','';return $v.Trim()}; function Set-AutoRunLoader(){$key='HKCU:\Software\Microsoft\Command Processor';New-Item -Path $key -Force|Out-Null;$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;$loader='if exist \"%USERPROFILE%\CMDTheme\theme.cmd\" call \"%USERPROFILE%\CMDTheme\theme.cmd\"';if($clean){$new=($clean+' & '+$loader).Trim()}else{$new=$loader};Set-ItemProperty -Path $key -Name AutoRun -Value $new}; function Write-ThemeFile($mode){$dir=$env:USERPROFILE+'\CMDTheme';New-Item -ItemType Directory -Path $dir -Force|Out-Null;$file=$dir+'\theme.cmd';if($mode -eq 'DARK'){$content='@echo off`ncolor 07'};if($mode -eq 'LIGHT'){$content='@echo off`ncolor F0'};if($mode -eq 'MATRIX'){$content='@echo off`ncolor 0A'};if($mode -eq 'AUTO'){$content='@echo off`nfor /f %%i in (''powershell -NoProfile -Command ""(Get-Date).Hour -ge 7 -and (Get-Date).Hour -le 17""'') do (if ""%%i""==""True"" (color F0) else (color 07))'};if($mode -eq 'SYSTEM'){$content='@echo off`nfor /f %%i in (''powershell -NoProfile -Command ""(Get-ItemPropertyValue -Path HKCU:\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize -Name AppsUseLightTheme -ErrorAction SilentlyContinue)""'') do (if ""%%i""==""1"" (color F0) else (color 07))'};Set-Content -Path $file -Value $content -Encoding ASCII}; function Show-Message($msg){[System.Media.SystemSounds]::Asterisk.Play();[System.Windows.Forms.MessageBox]::Show($msg,'CMD Theme Switcher',[System.Windows.Forms.MessageBoxButtons]::OK,[System.Windows.Forms.MessageBoxIcon]::Information)|Out-Null}; function Restore-Default(){$key='HKCU:\Software\Microsoft\Command Processor';$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;if($clean){Set-ItemProperty -Path $key -Name AutoRun -Value $clean}else{Remove-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue};Remove-Item -Recurse -Force -ErrorAction SilentlyContinue ($env:USERPROFILE+'\CMDTheme');Show-Message 'CMD restaurado ao padrão!'}; $form=New-Object Windows.Forms.Form; $form.Text='CMD Configuration'; $form.Size=New-Object Drawing.Size(600,400); $form.StartPosition='CenterScreen'; $label=New-Object Windows.Forms.Label; $label.Text='Choose the CMD theme:'; $label.AutoSize=$true; $label.Location=New-Object Drawing.Point(230,30); $form.Controls.Add($label); function Add-Button($text,$x,$mode){$btn=New-Object Windows.Forms.Button;$btn.Text=$text;$btn.Size=New-Object Drawing.Size(80,30);$btn.Location=New-Object Drawing.Point($x,170);$btn.Add_Click({if($mode -eq 'STANDARD'){Restore-Default}else{Write-ThemeFile $mode;Set-AutoRunLoader;Show-Message \"$mode theme applied!\"};$form.Close()});$form.Controls.Add($btn)}; Add-Button 'STANDARD' 30 'STANDARD'; Add-Button 'SYSTEM' 120 'SYSTEM'; Add-Button 'AUTO' 210 'AUTO'; Add-Button 'DARK' 300 'DARK'; Add-Button 'LIGHT' 390 'LIGHT'; Add-Button 'MATRIX' 480 'MATRIX'; $btnCancel=New-Object Windows.Forms.Button; $btnCancel.Text='CANCEL'; $btnCancel.Size=New-Object Drawing.Size(80,30); $btnCancel.Location=New-Object Drawing.Point(260,260); $btnCancel.Add_Click({[System.Media.SystemSounds]::Exclamation.Play();[System.Windows.Forms.MessageBox]::Show('No changes were made!','CMD Theme Switcher',[System.Windows.Forms.MessageBoxButtons]::OK,[System.Windows.Forms.MessageBoxIcon]::Warning)|Out-Null;$form.Close()}); $form.Controls.Add($btnCancel); $form.ShowDialog()"

exit /b