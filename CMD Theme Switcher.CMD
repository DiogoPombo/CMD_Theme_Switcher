@echo off
@title CMD Theme Switcher

where powershell >nul 2>&1
if %errorlevel% neq 0 (
    color 0c
    echo.
    echo ERROR: Windows PowerShell is required to run this application!
    echo Please install or enable Windows PowerShell and try again!
    pause
    exit /b
)


powershell -NoProfile -ExecutionPolicy Bypass -Command "Add-Type -AssemblyName System.Windows.Forms; function Clean-AutoRun($v){if(!$v){return $null};$v=$v -replace 'color [0-9A-Fa-f]{2}','';$v=$v -replace 'powershell -WindowStyle Hidden -EncodedCommand [A-Za-z0-9+/=]+','';return $v.Trim()}; function Set-Color($col){$key='HKCU:\Software\Microsoft\Command Processor';New-Item -Path $key -Force|Out-Null;$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;if($clean){$new=($clean+' color '+$col).Trim()}else{$new='color '+$col};Set-ItemProperty -Path $key -Name AutoRun -Value $new}; function Set-Auto(){$key='HKCU:\Software\Microsoft\Command Processor';New-Item -Path $key -Force|Out-Null;$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;$encoded=[Convert]::ToBase64String([Text.Encoding]::Unicode.GetBytes('$h=(Get-Date).Hour;if($h -ge 7 -and $h -le 17){[Console]::BackgroundColor=""White"";[Console]::ForegroundColor=""Black""}else{[Console]::BackgroundColor=""Black"";[Console]::ForegroundColor=""Gray""};[Console]::Clear()'));$cmd='powershell -WindowStyle Hidden -EncodedCommand '+$encoded;if($clean){$new=($clean+' '+$cmd).Trim()}else{$new=$cmd};Set-ItemProperty -Path $key -Name AutoRun -Value $new}; function Set-System(){$key='HKCU:\Software\Microsoft\Command Processor';New-Item -Path $key -Force|Out-Null;$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;$encoded=[Convert]::ToBase64String([Text.Encoding]::Unicode.GetBytes('$p=""HKCU:\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize"";try{$v=(Get-ItemProperty -Path $p -Name AppsUseLightTheme -ErrorAction Stop).AppsUseLightTheme}catch{$v=0};if($v -eq 1){[Console]::BackgroundColor=""White"";[Console]::ForegroundColor=""Black""}else{[Console]::BackgroundColor=""Black"";[Console]::ForegroundColor=""Gray""};[Console]::Clear()'));$cmd='powershell -WindowStyle Hidden -EncodedCommand '+$encoded;if($clean){$new=($clean+' '+$cmd).Trim()}else{$new=$cmd};Set-ItemProperty -Path $key -Name AutoRun -Value $new}; $form=New-Object Windows.Forms.Form; $form.Text='CMD Configuration'; $form.Size=New-Object Drawing.Size(600,400); $form.StartPosition='CenterScreen'; $label=New-Object Windows.Forms.Label; $label.Text='Choose the CMD theme:'; $label.AutoSize=$true; $label.Location=New-Object Drawing.Point(230,30); $form.Controls.Add($label); $btnStandard=New-Object Windows.Forms.Button; $btnStandard.Text='STANDARD'; $btnStandard.Location=New-Object Drawing.Point(30,170); $btnStandard.Add_Click({$key='HKCU:\Software\Microsoft\Command Processor';$current=(Get-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue).AutoRun;$clean=Clean-AutoRun $current;if($clean){Set-ItemProperty -Path $key -Name AutoRun -Value $clean}else{Remove-ItemProperty -Path $key -Name AutoRun -ErrorAction SilentlyContinue};[System.Windows.Forms.MessageBox]::Show('CMD restored to standard default theme!','Success');$form.Close()}); $form.Controls.Add($btnStandard); $btnSystem=New-Object Windows.Forms.Button; $btnSystem.Text='SYSTEM'; $btnSystem.Location=New-Object Drawing.Point(120,170); $btnSystem.Add_Click({Set-System;[System.Windows.Forms.MessageBox]::Show('System theme applied!','Success');$form.Close()}); $form.Controls.Add($btnSystem); $btnAuto=New-Object Windows.Forms.Button; $btnAuto.Text='AUTO'; $btnAuto.Location=New-Object Drawing.Point(210,170); $btnAuto.Add_Click({Set-Auto;[System.Windows.Forms.MessageBox]::Show('Auto theme applied!','Success');$form.Close()}); $form.Controls.Add($btnAuto); $btnDark=New-Object Windows.Forms.Button; $btnDark.Text='DARK'; $btnDark.Location=New-Object Drawing.Point(300,170); $btnDark.Add_Click({Set-Color '07';[System.Windows.Forms.MessageBox]::Show('Dark theme applied!','Success');$form.Close()}); $form.Controls.Add($btnDark); $btnLight=New-Object Windows.Forms.Button; $btnLight.Text='LIGHT'; $btnLight.Location=New-Object Drawing.Point(390,170); $btnLight.Add_Click({Set-Color 'f0';[System.Windows.Forms.MessageBox]::Show('Light theme applied!','Success');$form.Close()}); $form.Controls.Add($btnLight); $btnMatrix=New-Object Windows.Forms.Button; $btnMatrix.Text='MATRIX'; $btnMatrix.Location=New-Object Drawing.Point(480,170); $btnMatrix.Add_Click({Set-Color '0A';[System.Windows.Forms.MessageBox]::Show('Matrix theme applied!','Success');$form.Close()}); $form.Controls.Add($btnMatrix); $btnCancel=New-Object Windows.Forms.Button; $btnCancel.Text='CANCEL'; $btnCancel.Location=New-Object Drawing.Point(260,260); $btnCancel.Add_Click({[System.Windows.Forms.MessageBox]::Show('No changes were made!','Cancelled');$form.Close()}); $form.Controls.Add($btnCancel); $form.ShowDialog()"


exit /b